# docker compose 用の環境変数サンプル。
# 本ファイルをコピーして .env として保存し、必須項目を埋めること。
# `cp .env.example .env`

# --- 必須 ---

# AMI 認証用ユーザー名/シークレット (Web -> Asterisk 接続)。
# AMI_SECRET は十分に強い文字列にすること (英数記号 32 文字以上推奨)。
# 例: AMI_SECRET=$(openssl rand -base64 32)
AMI_USERNAME=command-room
AMI_SECRET=replace-with-strong-random-secret

# Next Server Action のハッシュ化を再ビルド間で安定させる encryption key。
# 例: NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=$(openssl rand -base64 32)
NEXT_SERVER_ACTIONS_ENCRYPTION_KEY=replace-with-base64-32bytes

# 初期 admin 作成用 (DB に account が 0 のときだけ使われる)。
# 8 文字以上必須。未設定だと admin は作成されず Web にログインできない。
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=replace-me-with-strong-password

# --- 任意 ---

# HTTPS リバプロを前段に置く場合のみ 1 にする (cookie secure=true)。
# NODE_ENV=production 単独では有効にならない (Docker compose は常に production
# だが http://localhost:3000 で運用するケースがあるため明示 opt-in 必須)。
COOKIE_SECURE=0

# --- event-v1 push (command-room ingest) ---
# 以下 3 つが揃ったときだけ web container の push loop が起動する。
# 未設定なら event は outbox に積まれるだけで送信されない (消えはしない)。
# EVENT_PUSH_URL=https://command-room.example.com/api/v1/external-events
# EVENT_PUSH_TOKEN=replace-with-device-token
# EVENT_PUSH_WORKSPACE_ID=00000000-0000-0000-0000-000000000000
# EVENT_PUSH_SOURCE_ACCOUNT_ID=                # 任意。未指定なら pbx:<pbxInstanceId>
# EVENT_PUSH_BATCH=20                          # 1 tick あたりの max 件数
# EVENT_PUSH_TIMEOUT_MS=15000                  # 1 リクエストの timeout

# --- event-v1 watcher (inbox → outbox 変換) ---
# compose の volume mount と揃える。production で永続化したい場合は host bind mount すること。
# EVENT_INBOX_DIR=/app/data/inbox
# EVENT_OUTBOX_V1_DIR=/app/data/outbox-v1
# OPENPBX_INSTANCE_ID=pbx-dev
# OPENPBX_WORKSPACE_KEY=workspace-dev
# EVENT_COMPUTE_RECORDING_METRICS=0            # 1 にすると sha256 を計算 (I/O 重)
